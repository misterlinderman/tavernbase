PORT=3001
NODE_ENV=development
MONGODB_URI=
AUTH0_DOMAIN=
AUTH0_AUDIENCE=

# Optional — Auth0 Management API for automated captain/player invite emails
AUTH0_MGMT_CLIENT_ID=
AUTH0_MGMT_CLIENT_SECRET=
AUTH0_MGMT_CONNECTION=Username-Password-Authentication
AUTH0_SPA_CLIENT_ID=

# First manager — used by: npx ts-node server/src/scripts/seedAdmin.ts
ADMIN_AUTH0_SUB=
ADMIN_EMAIL=
ADMIN_NAME=

# Optional league-only admin — used by: npx ts-node server/src/scripts/seedLeagueAdmin.ts
LEAGUE_ADMIN_AUTH0_SUB=
LEAGUE_ADMIN_EMAIL=
LEAGUE_ADMIN_NAME=

# Optional captain — used by: npx ts-node server/src/scripts/seedCaptain.ts
CAPTAIN_AUTH0_SUB=
CAPTAIN_EMAIL=
CAPTAIN_NAME=
CAPTAIN_PLAYER_ID=

# Optional league player — used by: npx ts-node server/src/scripts/seedPlayer.ts
PLAYER_AUTH0_SUB=
PLAYER_EMAIL=
PLAYER_NAME=
PLAYER_PLAYER_ID=

CLOUDINARY_URL=
CLOUDINARY_PENDING_FOLDER=tavernbase/pending
CLOUDINARY_PUBLIC_FOLDER=tavernbase/gallery
MAX_UPLOAD_BYTES=8000000
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_SUBMISSIONS=10

CLIENT_URL=http://localhost:5173

# Stripe (test mode) — league registration entry fees (L11)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_SUCCESS_URL=http://localhost:5173/register/payment/success?session_id={CHECKOUT_SESSION_ID}
# Per-registration success/cancel URLs are set automatically when checkout is created.
STRIPE_CANCEL_URL=http://localhost:5173/register

# Optional — transactional registration email (Phase 2, L12.5)
# When unset, approve/reject actions return copy/paste templates in the admin UI.
RESEND_API_KEY=
RESEND_FROM_EMAIL=Tavern Base <noreply@yourdomain.com>

# Production only — add Vercel preview URLs here if needed
